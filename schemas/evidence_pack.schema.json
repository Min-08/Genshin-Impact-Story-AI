{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/genshin-lore-db/evidence_pack.schema.json",
  "title": "Genshin Lore Evidence Pack",
  "type": "object",
  "required": ["schema_version", "query", "mode", "entities", "sources", "groups", "coverage", "quality"],
  "properties": {
    "schema_version": {
      "const": "evidence_pack.v0.5"
    },
    "generated_at": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["basic_lookup", "summary", "analysis", "research", "search", "investigate"]
    },
    "route": {
      "type": "object"
    },
    "entities": {
      "type": "object",
      "required": ["seed_concepts", "matched_aliases"],
      "properties": {
        "seed_concepts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "matched_aliases": {
          "type": "array"
        },
        "expanded_terms": {
          "type": "array"
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "result_id", "support_type", "title", "language", "excerpt"],
        "properties": {
          "source_id": {"type": "string"},
          "result_id": {"type": "string"},
          "canonical_id": {"type": ["string", "null"]},
          "document_id": {"type": ["string", "null"]},
          "support_type": {"type": "string"},
          "title": {"type": ["string", "null"]},
          "language": {"type": ["string", "null"]},
          "content_type": {"type": ["string", "null"]},
          "category": {"type": ["string", "null"]},
          "score": {"type": ["number", "null"]},
          "source_url": {"type": ["string", "null"]},
          "raw_refs": {"type": "array"},
          "excerpt": {"type": "string"}
        }
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "label", "count", "source_ids"],
        "properties": {
          "group_id": {"type": "string"},
          "label": {"type": "string"},
          "support_type": {"type": "string"},
          "count": {"type": "integer"},
          "source_ids": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "coverage": {
      "type": "object"
    },
    "quality": {
      "type": "object"
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
