{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/genshin-lore-db/answer_evaluation_case.schema.json",
  "title": "Genshin Lore Answer Evaluation Set",
  "type": "object",
  "required": ["version", "cases"],
  "properties": {
    "version": {"type": "string"},
    "description": {"type": "string"},
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "query", "expected_intent"],
        "properties": {
          "id": {"type": "string"},
          "query": {"type": "string"},
          "expected_route": {"type": "string"},
          "expected_intent": {"type": "string"},
          "expected_content_type": {"type": ["string", "null"]},
          "expected_canonical_id": {"type": ["string", "null"]},
          "expected_item_id": {"type": ["string", "null"]},
          "required_fragments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "forbidden_fragments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "notes": {"type": "string"}
        }
      }
    },
    "thresholds": {
      "type": "object"
    }
  }
}
